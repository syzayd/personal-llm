# Copy to .env and fill in real values. Never commit .env.

# Cloud model (free tier, no credit card needed): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional local model via Ollama (https://ollama.com). If unset or Ollama
# isn't running, the engine falls back to Gemini for chat completions.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Data locations (defaults shown; usually leave these alone)
PERSONAL_LLM_DATA_DIR=./data
PERSONAL_LLM_DB_PATH=./data/personal_llm.db
PERSONAL_LLM_CHROMA_DIR=./data/chroma
